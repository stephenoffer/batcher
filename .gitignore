# Rust
/target
**/*.rs.bk
# Cargo.lock IS committed: the engine ships as a wheel and we want reproducible builds.

# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.hypothesis/
build/
dist/
*.so
.coverage
.coverage.*

# Editor / OS
.DS_Store
.idea/
.vscode/

# Built documentation site
docs/_build/
# autosummary-generated API stubs (regenerated on every build)
docs/api/generated/
# Intermediate Graphviz sources (generated by docs/_static/diagrams/render.py;
# the rendered .png files are committed).
docs/_static/diagrams/*.dot
